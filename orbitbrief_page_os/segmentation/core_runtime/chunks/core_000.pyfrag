    ORANGE as _ORANGE,
    PURPLE as _PURPLE,
    SUBHDR as _SUBHDR,
)
from .overlay.draw_blue_outlines import (
    draw_regular_blue_wrappers,
    draw_synthetic_blue_bodies,
)
