"""Standalone visible-box detector.

Primary engine: pypdfium2 + OpenCV (no orbitbrief imports needed for the box
pipeline).  PyMuPDF is imported lazily and only when the optional
font-aware text-section detection is enabled (Cfg.detect_text_sections).

Run:
    python detect_standalone.py --pdf path/to/file.pdf --page 0 --out overlay.png
"""
from __future__ import annotations

