                # ``first_logical``; detect it here and pair with the row at
                # ``seed_y`` (RPM / HP / …) as ``subhdr_*`` + ``colhdr_*``.
                _sched_tit = (_fpage.get_textbox(
                    _img_to_pdf_rect2(tx0, ty0, tx1, ty1)) or "")
                # Tight clip **only** for comparing a thin ORANGE strip to this
                # title — the full ``*_title`` bbox often bleeds into the next
                # section's ``… SCHEDULE`` string in ``get_textbox``.
                _th = max(ty1 - ty0, 1)
                _tw = max(tx1 - tx0, 1)
                _t_y0 = int(ty0 + min(10, int(0.22 * _th)))
                _t_y1 = int(ty1 - min(6, int(0.10 * _th)))
                _t_x0 = int(tx0 + min(14, int(0.20 * _tw)))
                _t_x1 = int(tx1 - min(14, int(0.20 * _tw)))
                if _t_y1 <= _t_y0 or _t_x1 <= _t_x0:
                    _t_y0, _t_y1, _t_x0, _t_x1 = ty0, ty1, tx0, tx1
                _sched_tit_trim = (_fpage.get_textbox(
                    _img_to_pdf_rect2(_t_x0, _t_y0, _t_x1, _t_y1)) or "")
                _tit_for_dup = (
                    (_sched_tit_trim or "").strip()
                    or (_sched_tit or "").strip())
