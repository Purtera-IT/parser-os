                strip_two = False
                _h_hdr = _row_median_h(first_row)
                _h_follow = (_row_median_h(second_row) if second_row else 99.0)
                # Hairline / sub-label row under TAG|RPM|… is short; do **not**
                # use ``_row_is_data_row`` here — numeric-only slivers read as data.
