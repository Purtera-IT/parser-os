                        _tit_for_dup = " ".join(
                            w[4] for w in _words if w[4]).strip()
                span_xw = max(80, sx1 - sx0)
                strip_cands = [
                    c for c in orange_cells
                    if seed_y - 38 <= c.px_bbox[1] < seed_y - 1
                    and 5 <= (c.px_bbox[3] - c.px_bbox[1]) <= 38
                    and (c.px_bbox[2] - c.px_bbox[0]) > 0.45 * span_xw
                    and c.px_bbox[2] > _hx0 - 40 and c.px_bbox[0] < _hx1 + 40
                ]
