                # attach (BOILER-style).
                if (strip_cands
                        and re.search(r"\bSCHEDULE\b", _sched_tit, re.I)
                        and max(c.px_bbox[3] for c in strip_cands) <= seed_y + 14
                        and second_seed is not None
                        and _thin_follow):
                    third_seed_st = min(
                        (c.px_bbox[1] for c in orange_cells
                         if c.px_bbox[1] > second_seed + 5
                         and c.px_bbox[2] > _hx0 - 50
                         and c.px_bbox[0] < _hx1 + 50),
                        default=None,
                    )
                    if third_seed_st is not None:
                        tr_st = [c for c in orange_cells
                                 if abs(c.px_bbox[1] - third_seed_st) <= 5
                                 and c.px_bbox[2] > _hx0
                                 and c.px_bbox[0] < _hx1]
                        if _row_is_data_row(tr_st):
                            strip_two = True
                            two_tier = True
